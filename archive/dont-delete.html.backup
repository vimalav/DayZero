<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>watsonx Orchestrate - Jobs-First v1.4 (Customer Care)</title>
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/@carbon/web-components@latest/es/components/icon/index.css"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <!-- Persona Selection Overlay -->
    <div class="persona-selector-overlay" id="personaOverlay">
      <div class="persona-modal">
        <div id="personaScreen">
          <h2>Welcome to watsonx Orchestrate</h2>
          <p class="description">
            To give you the best experience, please select your primary role.
            We'll tailor the interface, guidance, and features to match your
            needs.
          </p>
          <p class="reassurance">
            <strong>Don't worry</strong> - you can switch roles anytime or work
            in multiple roles.
          </p>

          <div class="persona-cards">
            <div class="persona-card" data-persona="admin">
              <div class="persona-icon">⚙️</div>
              <h3>Admin</h3>
              <p>I manage the platform and enable teams</p>
              <div class="focus-areas">
                <strong>You'll focus on:</strong>
                <ul>
                  <li>Setting up integrations</li>
                  <li>Managing connections</li>
                  <li>Configuring access</li>
                  <li>Monitoring usage</li>
                </ul>
              </div>
            </div>

            <div class="persona-card" data-persona="builder">
              <div class="persona-icon">🔨</div>
              <h3>Builder</h3>
              <p>I solve customer care challenges with AI agents</p>
              <div class="focus-areas">
                <strong>You'll focus on:</strong>
                <ul>
                  <li>Reducing ticket volume</li>
                  <li>Speeding up inquiries</li>
                  <li>Automating processes</li>
                  <li>Improving satisfaction</li>
                </ul>
              </div>
            </div>

            <div class="persona-card" data-persona="sme">
              <div class="persona-icon">💡</div>
              <h3>Subject Matter Expert</h3>
              <p>I validate agents with customer service expertise</p>
              <div class="focus-areas">
                <strong>You'll focus on:</strong>
                <ul>
                  <li>Testing accuracy</li>
                  <li>Validating responses</li>
                  <li>Ensuring quality</li>
                  <li>Providing feedback</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="persona-actions">
            <div class="persona-actions-left">
              <button class="persona-btn tertiary" onclick="showAssessment()">
                I'm not sure - Help me choose
              </button>
              <button class="persona-btn tertiary" onclick="showRoleGuide()">
                Learn about each role
              </button>
            </div>
            <div class="persona-actions-right">
              <button class="persona-btn secondary" onclick="skipOnboarding()">
                Skip for now
              </button>
              <button
                class="persona-btn primary"
                id="continueBtn"
                disabled
                onclick="continueToLanding()"
              >
                Continue
              </button>
            </div>
          </div>
        </div>

        <!-- Assessment Screen -->
        <div id="assessmentScreen" style="display: none">
          <h2>Let's find your best role</h2>
          <p class="description">
            Answer 3 quick questions to help us recommend the right role for
            you.
          </p>

          <div class="progress-indicator">
            <div class="progress-dot active" id="progress-1"></div>
            <div class="progress-dot" id="progress-2"></div>
            <div class="progress-dot" id="progress-3"></div>
          </div>

          <div id="question-1" class="assessment-question">
            <h3>1. What will you primarily do in watsonx Orchestrate?</h3>
            <div class="assessment-options">
              <label class="assessment-option">
                <input type="radio" name="q1" value="admin" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Set up and manage the platform
                  </div>
                  <div class="assessment-option-desc">
                    Configure connections, manage users, monitor usage
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q1" value="builder" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Solve customer care challenges
                  </div>
                  <div class="assessment-option-desc">
                    Build agents to reduce tickets, speed up inquiries, automate
                    processes
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q1" value="sme" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Validate and improve agents
                  </div>
                  <div class="assessment-option-desc">
                    Test accuracy, provide feedback, ensure quality
                  </div>
                </div>
              </label>
            </div>
          </div>

          <div
            id="question-2"
            class="assessment-question"
            style="display: none"
          >
            <h3>2. What's your technical comfort level?</h3>
            <div class="assessment-options">
              <label class="assessment-option">
                <input type="radio" name="q2" value="admin" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    I manage IT systems and infrastructure
                  </div>
                  <div class="assessment-option-desc">
                    Comfortable with system configuration and user management
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q2" value="builder" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    I build solutions for business problems
                  </div>
                  <div class="assessment-option-desc">
                    Comfortable with tools and workflows
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q2" value="sme" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    I provide domain expertise
                  </div>
                  <div class="assessment-option-desc">
                    Focus on content accuracy and business knowledge
                  </div>
                </div>
              </label>
            </div>
          </div>

          <div
            id="question-3"
            class="assessment-question"
            style="display: none"
          >
            <h3>3. What's your immediate goal?</h3>
            <div class="assessment-options">
              <label class="assessment-option">
                <input type="radio" name="q3" value="admin" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Get the platform ready for my team
                  </div>
                  <div class="assessment-option-desc">
                    Set up connections, configure access, enable builders
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q3" value="builder" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Solve a customer care challenge
                  </div>
                  <div class="assessment-option-desc">
                    Reduce tickets, speed up inquiries, or automate processes
                  </div>
                </div>
              </label>
              <label class="assessment-option">
                <input type="radio" name="q3" value="sme" />
                <div class="assessment-option-content">
                  <div class="assessment-option-title">
                    Ensure agent quality and accuracy
                  </div>
                  <div class="assessment-option-desc">
                    Review, test, and provide expert feedback
                  </div>
                </div>
              </label>
            </div>
          </div>

          <div class="persona-actions">
            <div class="persona-actions-left"></div>
            <div class="persona-actions-right">
              <button class="persona-btn secondary" onclick="backToPersona()">
                Back
              </button>
              <button
                class="persona-btn primary"
                id="assessmentNextBtn"
                disabled
                onclick="nextAssessmentQuestion()"
              >
                Next
              </button>
            </div>
          </div>
        </div>

        <!-- Assessment Result Screen -->
        <div id="assessmentResultScreen" style="display: none">
          <h2>We recommend: <span id="recommended-role"></span></h2>
          <p class="description" id="recommendation-reason"></p>

          <div class="info-banner">
            <div class="info-banner-title">Remember</div>
            <div class="info-banner-text">
              You can always switch roles later or work in multiple roles. This
              is just your starting point.
            </div>
          </div>

          <div class="persona-actions">
            <div class="persona-actions-left"></div>
            <div class="persona-actions-right">
              <button class="persona-btn secondary" onclick="backToPersona()">
                Choose a different role
              </button>
              <button
                class="persona-btn primary"
                onclick="acceptRecommendation()"
              >
                Continue with this role
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main App Content -->
    <div
      id="appContent"
      style="
        display: none;
        height: 100vh;
        display: flex;
        flex-direction: column;
      "
    >
      <header class="app-header">
        <div class="header-content">
          <button
            class="hamburger-menu"
            id="hamburgerMenu"
            aria-label="Open menu"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 4h16v2H2V4zm0 5h16v2H2V9zm0 5h16v2H2v-2z" />
            </svg>
          </button>
          <div class="brand">
            <span class="brand-ibm">IBM</span
            ><span class="brand-product">watsonx Orchestrate</span>
          </div>
          <button class="persona-badge" id="personaBadge"></button>
        </div>
      </header>

      <div class="main-layout">
        <aside class="ai-chat-panel">
          <div class="chat-header">
            <h3>AI Chat</h3>
          </div>
          <div class="chat-messages" id="chatMessages">
            <!-- Dynamic content -->
          </div>
          <div class="chat-input-wrapper">
            <textarea
              class="chat-input"
              rows="2"
              placeholder="Ask me anything..."
              id="chatInput"
            ></textarea>
          </div>
        </aside>

        <div class="content-area">
          <!-- Collapsible Page Header (IBM Carbon Pattern) -->
          <div class="page-header collapsed" id="pageHeader">
            <div class="page-header-toggle" onclick="togglePageHeader()">
              <div class="page-header-title">
                <h2>Getting Started</h2>
                <span class="page-header-subtitle"
                  >Quick setup and guidance</span
                >
              </div>
              <button
                class="page-header-toggle-btn"
                aria-label="Toggle getting started section"
              >
                <svg
                  class="page-header-chevron"
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                >
                  <path d="M8 11L3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z" />
                </svg>
              </button>
            </div>
            <div class="page-header-content">
              <p class="page-header-description">
                Access setup guides, tutorials, and quick actions to help you
                get the most out of watsonx Orchestrate. This panel stays
                available even after you've built your first agents.
              </p>
              <div id="pageHeaderCards"></div>
            </div>
          </div>

          <div class="hero-section">
            <div class="hero-content" id="heroContent">
              <!-- Dynamic content -->
            </div>
          </div>

          <div class="main-content" id="mainContent">
            <!-- Dynamic content -->
          </div>
        </div>
      </div>
    </div>

    <!-- Job Details Modal -->
    <div class="job-modal-overlay" id="jobModal" style="display: none">
      <div class="job-modal">
        <div class="job-modal-header">
          <h2 id="jobModalTitle"></h2>
          <button
            class="job-modal-close"
            onclick="closeJobModal()"
            aria-label="Close"
          >
            <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor">
              <path
                d="M24 9.4L22.6 8 16 14.6 9.4 8 8 9.4 14.6 16 8 22.6 9.4 24 16 17.4 22.6 24 24 22.6 17.4 16 24 9.4z"
              />
            </svg>
          </button>
        </div>
        <div class="job-modal-content" id="jobModalContent">
          <!-- Dynamic content -->
        </div>
      </div>
    </div>

    <!-- Connection Setup Modal -->
    <div
      class="connection-modal-overlay"
      id="connectionModal"
      style="display: none"
    >
      <div class="connection-modal">
        <div class="connection-modal-header">
          <h2 id="connectionModalTitle">Connect your first app</h2>
          <button
            class="connection-modal-close"
            onclick="closeConnectionModal()"
            aria-label="Close"
          >
            <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor">
              <path
                d="M24 9.4L22.6 8 16 14.6 9.4 8 8 9.4 14.6 16 8 22.6 9.4 24 16 17.4 22.6 24 24 22.6 17.4 16 24 9.4z"
              />
            </svg>
          </button>
        </div>
        <div class="connection-modal-content" id="connectionModalContent">
          <!-- Dynamic content -->
        </div>
      </div>
    </div>

    <script src="app-v1.4.js"></script>
  </body>
</html>
